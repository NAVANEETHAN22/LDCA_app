<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="48dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Single Payload Prediction"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter the payload string below to get a prediction."
            android:textColor="#555555"
            android:textSize="14sp"
            android:paddingBottom="24dp"/>

        <!-- Payload input field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter payload (e.g. &lt;script>alert(1)&lt;/script>)"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/payloadInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="3"
                android:gravity="top"
                android:inputType="textMultiLine"/>

        </com.google.android.material.textfield.TextInputLayout>

        <ProgressBar
            android:id="@+id/payloadLoadingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Model"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:paddingBottom="8dp"/>

        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:entries="@array/model_options"
            android:background="@android:drawable/btn_dropdown"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPredict"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:text="Predict"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/predictionResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: LOADING"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="8dp"/>

                <TextView
                    android:id="@+id/predictionDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Confidence: --%"
                    android:textSize="14sp"
                    android:textColor="#222222"
                    android:gravity="center"
                    android:paddingBottom="12dp"/>

                <!-- Risk Meter -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Risk Level"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    android:id="@+id/riskMeter"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progressDrawable="@drawable/risk_progress_bar"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analysis Breakdown"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/analysisBreakdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analyzing payload characteristics..."
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="8dp"/>

                <!-- Advanced Analysis -->
                <TextView
                    android:id="@+id/advancedAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/decodedPayloadTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Decoded Version:"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/decodedPayloadText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F0F0F0"
                    android:padding="8dp"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textColor="#333333"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadPayload"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Download PDF Report"
                    android:textSize="14sp"
                    app:cornerRadius="12dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
